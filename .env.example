# Copy this file to .env.local and fill in your Supabase project's values.
# Without these the app runs in demo mode (seeded pins + localStorage).
#
# Get them from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Server-only (writes, matching, emails). Never expose to the browser. ---
# Supabase Dashboard → Project Settings → API → service_role key
# REQUIRED for live mode since schema v4: all writes go through /api/submit.
SUPABASE_SERVICE_ROLE_KEY=

# --- Abuse protection (optional): Cloudflare Turnstile captcha -------------
# Get both from dash.cloudflare.com → Turnstile. With no keys set, forms skip
# the captcha but per-IP rate limits still apply.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# --- Notifications: AWS (SES email + SNS SMS) preferred, Resend fallback ---
# With AWS creds set, emails go via SES; otherwise Resend; otherwise skipped.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# SMS via AWS SNS only sends when this is exactly "true" (needs AWS creds too).
# Note: sending SMS to Indian numbers requires DLT registration — see README.
SMS_ENABLED=
# resend.com API key — fallback email provider when AWS isn't configured
RESEND_API_KEY=
# Verified sender (must be a verified identity in SES if using AWS),
# e.g. "BombayRent <match@yourdomain.com>"
MATCH_FROM_EMAIL=
# Any random string; protects /api/match from strangers triggering it
CRON_SECRET=
